{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariadne.dev/schema/ariadne-control-catalog-v1.schema.json",
  "title": "Ariadne Control Catalog v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "run_kind",
    "mode",
    "agent",
    "status_filter",
    "summary",
    "controls",
    "families",
    "proof_specs",
    "verification_tasks",
    "redaction",
    "limitations"
  ],
  "properties": {
    "schema_version": { "const": "ariadne.report/v1" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "run_kind": { "type": "string", "enum": ["control_catalog", "control_catalog_scan"] },
    "target_path": { "type": "string" },
    "mode": { "type": "string" },
    "agent": { "type": "string" },
    "status_filter": { "type": "string", "enum": ["all", "breaking", "controlled", "unknown", "not_observed", "observed"] },
    "summary": { "$ref": "#/$defs/control_catalog_summary" },
    "controls": {
      "type": "array",
      "items": { "$ref": "ariadne-architecture-v1.schema.json#/$defs/architecture_closure" }
    },
    "families": {
      "type": "array",
      "items": { "$ref": "ariadne-architecture-v1.schema.json#/$defs/architecture_closure_family" }
    },
    "proof_specs": {
      "type": "array",
      "items": { "$ref": "#/$defs/control_proof_spec" }
    },
    "verification_tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/control_verification_task" }
    },
    "redaction": { "$ref": "ariadne-architecture-v1.schema.json#/$defs/redaction" },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "control_catalog_summary": {
      "type": "object",
      "required": ["controls", "critical", "high", "medium", "low", "targets", "flaws"],
      "properties": {
        "controls": { "type": "integer" },
        "critical": { "type": "integer" },
        "high": { "type": "integer" },
        "medium": { "type": "integer" },
        "low": { "type": "integer" },
        "targets": { "type": "integer" },
        "flaws": { "type": "integer" }
      }
    },
    "control_proof_spec": {
      "type": "object",
      "required": ["control", "evidence_kind", "proof_surfaces", "recognized_indicators", "notes", "limitations"],
      "properties": {
        "control": { "type": "string" },
        "evidence_kind": { "type": "string" },
        "proof_surfaces": { "type": "array", "items": { "type": "string" } },
        "recognized_indicators": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "control_verification_task": {
      "type": "object",
      "required": ["id", "control", "severity", "targets", "question", "why", "evidence_refs", "proof_surfaces", "recognized_indicators", "actions", "rerun_commands", "success_criteria", "limitations"],
      "properties": {
        "id": { "type": "string" },
        "control": { "type": "string" },
        "severity": { "type": "string" },
        "targets": { "type": "array", "items": { "type": "string" } },
        "question": { "type": "string" },
        "why": { "type": "string" },
        "evidence_refs": { "type": "array", "items": { "$ref": "ariadne-architecture-v1.schema.json#/$defs/evidence_reference" } },
        "proof_surfaces": { "type": "array", "items": { "type": "string" } },
        "recognized_indicators": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "rerun_commands": { "type": "array", "items": { "type": "string" } },
        "success_criteria": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
