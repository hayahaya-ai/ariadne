{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariadne.dev/schema/ariadne-scan-v1.schema.json",
  "title": "Ariadne Scan v1",
  "type": "object",
  "required": ["schema_version", "run_id", "generated_at", "run_kind", "summary", "targets"],
  "properties": {
    "schema_version": { "const": "ariadne.report/v1" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "run_kind": { "const": "scan" },
    "mode": { "type": "string" },
    "agent": { "type": "string" },
    "summary": {
      "type": "object",
      "properties": {
        "targets": { "type": "integer" },
        "completed": { "type": "integer" },
        "errors": { "type": "integer" },
        "exposed": { "type": "integer" },
        "protected": { "type": "integer" },
        "inconclusive": { "type": "integer" },
        "exposure_paths": { "type": "integer" },
        "critical": { "type": "integer" },
        "high": { "type": "integer" },
        "medium": { "type": "integer" },
        "low": { "type": "integer" },
        "info": { "type": "integer" }
      }
    },
    "interpretation": { "$ref": "#/$defs/interpretation" },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target"],
        "properties": {
          "target": { "type": "object" },
          "report": { "type": "object" },
          "error": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "interpretation": {
      "type": "object",
      "required": ["mode", "engine", "summary", "issues", "limitations"],
      "properties": {
        "mode": { "type": "string" },
        "engine": { "type": "string" },
        "future_modes": { "type": "array", "items": { "type": "string" } },
        "summary": { "$ref": "#/$defs/issue_summary" },
        "issues": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
        "limitations": { "type": "array", "items": { "type": "string" } },
        "policy_source": { "type": "string" }
      }
    },
    "issue_summary": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "critical": { "type": "integer" },
        "high": { "type": "integer" },
        "medium": { "type": "integer" },
        "low": { "type": "integer" },
        "info": { "type": "integer" },
        "fix_now": { "type": "integer" },
        "review": { "type": "integer" },
        "monitor": { "type": "integer" },
        "controlled": { "type": "integer" },
        "expected": { "type": "integer" }
      }
    },
    "issue": {
      "type": "object",
      "required": ["id", "title", "severity", "priority", "disposition", "rule_id", "rule_source", "interpretation_mode"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
        "priority": { "type": "string", "enum": ["p0", "p1", "p2", "p3", "p4"] },
        "disposition": { "type": "string", "enum": ["fix_now", "review", "monitor", "controlled", "expected_capability"] },
        "category": { "type": "string" },
        "exposure_id": { "type": "string" },
        "exposure_status": { "type": "string", "enum": ["exposed", "protected", "inconclusive"] },
        "rule_id": { "type": "string" },
        "rule_source": { "type": "string" },
        "interpretation_mode": { "type": "string" },
        "affected_target": { "type": "string" },
        "rationale": { "type": "string" },
        "signals": { "type": "array", "items": { "type": "string" } },
        "graph_edges": { "type": "array", "items": { "type": "string" } },
        "controls": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string" }
      }
    }
  }
}
