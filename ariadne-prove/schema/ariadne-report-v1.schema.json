{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariadne.dev/schema/ariadne-report-v1.schema.json",
  "title": "Ariadne Report v1",
  "type": "object",
  "required": ["schema_version", "run_id", "generated_at", "run_kind", "graph", "redaction", "limitations"],
  "properties": {
    "schema_version": { "const": "ariadne.report/v1" },
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "run_kind": { "type": "string", "enum": ["story", "path"] },
    "target_path": { "type": "string" },
    "exposures": {
      "type": "array",
      "items": { "$ref": "#/$defs/exposure" }
    },
    "graph": { "$ref": "#/$defs/graph" },
    "interpretation": { "$ref": "#/$defs/interpretation" },
    "zero_trust": { "$ref": "#/$defs/zero_trust" },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    },
    "redaction": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "exposure": {
      "type": "object",
      "required": ["id", "title", "status", "proof_mode", "path_nodes", "path_edges", "evidence_refs", "observation"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["exposed", "protected", "inconclusive"] },
        "proof_mode": { "type": "string", "enum": ["inferred", "simulated", "live_lab"] },
        "path_nodes": { "type": "array", "items": { "type": "string" } },
        "path_edges": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_reference" }
        },
        "observation": { "type": "object" }
      }
    },
    "evidence_reference": {
      "type": "object",
      "required": ["id", "kind", "summary"],
      "properties": {
        "target": { "type": "string" },
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "source": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "summary": { "type": "string" }
      }
    },
    "graph": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": { "type": "array", "items": { "type": "object" } },
        "edges": { "type": "array", "items": { "type": "object" } }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["id", "kind", "grade", "summary"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "grade": { "type": "string" },
        "source": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "zero_trust": {
      "type": "object",
      "required": ["framework_version", "summary", "architecture_summary", "architecture_flaws", "coverage", "maturity", "checks"],
      "properties": {
        "framework_version": { "const": "ariadne.zero_trust_agent/v1" },
        "summary": { "$ref": "#/$defs/zero_trust_summary" },
        "architecture_summary": { "$ref": "#/$defs/zero_trust_summary" },
        "architecture_flaws": {
          "type": "array",
          "items": { "$ref": "#/$defs/zero_trust_architecture" }
        },
        "coverage": { "$ref": "#/$defs/zero_trust_coverage" },
        "maturity": { "$ref": "#/$defs/zero_trust_maturity" },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/zero_trust_check" }
        }
      }
    },
    "zero_trust_summary": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "breaking": { "type": "integer" },
        "controlled": { "type": "integer" },
        "unknown": { "type": "integer" },
        "not_observed": { "type": "integer" }
      }
    },
    "zero_trust_coverage": {
      "type": "object",
      "required": ["known", "gaps", "unknown", "not_observed", "gap_details"],
      "properties": {
        "known": { "type": "integer" },
        "gaps": { "type": "integer" },
        "unknown": { "type": "integer" },
        "not_observed": { "type": "integer" },
        "gap_details": {
          "type": "array",
          "items": { "$ref": "#/$defs/zero_trust_gap" }
        }
      }
    },
    "zero_trust_gap": {
      "type": "object",
      "required": ["check_id", "boundary", "status", "missing_evidence", "why_it_matters", "next_collector"],
      "properties": {
        "check_id": { "type": "string" },
        "boundary": { "type": "string" },
        "status": { "type": "string", "enum": ["breaking", "controlled", "unknown", "not_observed"] },
        "missing_evidence": { "type": "array", "items": { "type": "string" } },
        "why_it_matters": { "type": "string" },
        "next_collector": { "type": "string" }
      }
    },
    "zero_trust_maturity": {
      "type": "object",
      "required": ["target_tier", "summary", "requirements"],
      "properties": {
        "target_tier": { "type": "string", "enum": ["foundation", "enterprise", "advanced"] },
        "summary": { "$ref": "#/$defs/zero_trust_maturity_summary" },
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/zero_trust_requirement" }
        }
      }
    },
    "zero_trust_maturity_summary": {
      "type": "object",
      "required": ["total", "met", "gaps", "breaking", "unknown", "not_observed", "hard_barriers", "friction_only"],
      "properties": {
        "total": { "type": "integer" },
        "met": { "type": "integer" },
        "gaps": { "type": "integer" },
        "breaking": { "type": "integer" },
        "unknown": { "type": "integer" },
        "not_observed": { "type": "integer" },
        "hard_barriers": { "type": "integer" },
        "friction_only": { "type": "integer" }
      }
    },
    "zero_trust_requirement": {
      "type": "object",
      "required": ["id", "tier", "principle", "capability", "status", "control_quality", "finding", "evidence", "actions"],
      "properties": {
        "id": { "type": "string" },
        "tier": { "type": "string", "enum": ["foundation", "enterprise", "advanced"] },
        "principle": { "type": "string" },
        "capability": { "type": "string" },
        "status": { "type": "string", "enum": ["breaking", "controlled", "unknown", "not_observed"] },
        "control_quality": { "type": "string" },
        "finding": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/zero_trust_evidence" }
        },
        "controls": { "type": "array", "items": { "type": "string" } },
        "missing_evidence": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "zero_trust_check": {
      "type": "object",
      "required": ["id", "principle", "boundary", "tier", "status", "design_test", "finding", "evidence", "graph_edges", "actions"],
      "properties": {
        "id": { "type": "string" },
        "principle": { "type": "string" },
        "boundary": { "type": "string" },
        "tier": { "type": "string", "enum": ["foundation", "enterprise", "advanced"] },
        "status": { "type": "string", "enum": ["breaking", "controlled", "unknown", "not_observed"] },
        "design_test": { "type": "string" },
        "finding": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/zero_trust_evidence" }
        },
        "graph_edges": { "type": "array", "items": { "type": "string" } },
        "controls": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "zero_trust_architecture": {
      "type": "object",
      "required": ["id", "title", "status", "severity", "principle", "tier", "boundaries", "check_ids", "finding", "why_it_matters", "control_test", "evidence", "graph_edges", "control_evidence_needed", "evidence_surfaces", "actions"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["breaking", "controlled", "unknown", "not_observed"] },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
        "principle": { "type": "string" },
        "tier": { "type": "string", "enum": ["foundation", "enterprise", "advanced"] },
        "boundaries": { "type": "array", "items": { "type": "string" } },
        "check_ids": { "type": "array", "items": { "type": "string" } },
        "finding": { "type": "string" },
        "why_it_matters": { "type": "string" },
        "control_test": { "$ref": "#/$defs/architecture_control_test" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/zero_trust_evidence" }
        },
        "graph_edges": { "type": "array", "items": { "type": "string" } },
        "controls": { "type": "array", "items": { "type": "string" } },
        "control_evidence_needed": { "type": "array", "items": { "type": "string" } },
        "evidence_surfaces": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "architecture_control_test": {
      "type": "object",
      "required": ["question", "result", "summary", "hard_barriers_observed", "partial_or_friction_controls", "missing_hard_barriers"],
      "properties": {
        "question": { "type": "string" },
        "result": { "type": "string", "enum": ["hard_barrier_observed", "missing_hard_barrier", "partial_or_friction_only", "evidence_gap", "not_observed"] },
        "summary": { "type": "string" },
        "hard_barriers_observed": { "type": "array", "items": { "type": "string" } },
        "partial_or_friction_controls": { "type": "array", "items": { "type": "string" } },
        "missing_hard_barriers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "zero_trust_evidence": {
      "type": "object",
      "required": ["id", "kind", "summary"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "source": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "interpretation": {
      "type": "object",
      "required": ["mode", "engine", "summary", "issues", "limitations"],
      "properties": {
        "mode": { "type": "string" },
        "engine": { "type": "string" },
        "available_modes": { "type": "array", "items": { "type": "string" } },
        "future_modes": { "type": "array", "items": { "type": "string" } },
        "summary": { "$ref": "#/$defs/issue_summary" },
        "issues": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
        "limitations": { "type": "array", "items": { "type": "string" } },
        "policy_source": { "type": "string" },
        "review_source": { "type": "string" },
        "request_digest": { "type": "string" }
      }
    },
    "issue_summary": {
      "type": "object",
      "properties": {
        "total": { "type": "integer" },
        "critical": { "type": "integer" },
        "high": { "type": "integer" },
        "medium": { "type": "integer" },
        "low": { "type": "integer" },
        "info": { "type": "integer" },
        "fix_now": { "type": "integer" },
        "review": { "type": "integer" },
        "monitor": { "type": "integer" },
        "controlled": { "type": "integer" },
        "expected": { "type": "integer" }
      }
    },
    "issue": {
      "type": "object",
      "required": ["id", "title", "severity", "priority", "disposition", "rule_id", "rule_source", "interpretation_mode"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
        "priority": { "type": "string", "enum": ["p0", "p1", "p2", "p3", "p4"] },
        "disposition": { "type": "string", "enum": ["fix_now", "review", "monitor", "controlled", "expected_capability"] },
        "category": { "type": "string" },
        "exposure_id": { "type": "string" },
        "exposure_status": { "type": "string", "enum": ["exposed", "protected", "inconclusive"] },
        "rule_id": { "type": "string" },
        "rule_source": { "type": "string" },
        "interpretation_mode": { "type": "string" },
        "affected_target": { "type": "string" },
        "rationale": { "type": "string" },
        "signals": { "type": "array", "items": { "type": "string" } },
        "graph_edges": { "type": "array", "items": { "type": "string" } },
        "controls": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string" }
      }
    }
  }
}
